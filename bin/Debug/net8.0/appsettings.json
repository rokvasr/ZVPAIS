{
  "ConnectionStrings": {
    "DefaultConnection": "Host=zpvis-postgres.postgres.database.azure.com;Database=zpvisDB;Username=zpvisadmin;Password=#{MyPassword}#;SslMode=Require"
  },
  "Jwt": {
    "Key": "PLACEHOLDER_REPLACE_WITH_SECRET_MIN_32_CHARS_IN_PRODUCTION",
    "Issuer": "ZVPAIS_API",
    "Audience": "ZVPAIS_Client",
    "ExpiresInHours": 24
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EventProcessing": {
    "DelayMinutes": 0,
    "PollingIntervalSeconds": 5
  }
}